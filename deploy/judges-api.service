[Unit]
Description=Judges Bot API (FastAPI)
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/judges_bot_v2
EnvironmentFile=/home/YOUR_USER/judges_bot_v2/.env
ExecStart=/home/YOUR_USER/judges_bot_v2/venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8100
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
