[Unit]
Description=Judges Telegram Bot
After=network.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/judges_bot_v2
EnvironmentFile=/home/YOUR_USER/judges_bot_v2/.env
ExecStart=/home/YOUR_USER/judges_bot_v2/venv/bin/python -m main
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
